{
  "components": {
    "schemas": {
      "ChoreStatus": {
        "enum": [
          "PENDING",
          "COMPLETED"
        ],
        "type": "string"
      },
      "CreateBillDto": {
        "properties": {
          "currency": {
            "description": "Three-letter ISO currency code. Defaults to USD.",
            "example": "USD",
            "type": "string"
          },
          "description": {
            "description": "Optional bill description.",
            "example": "Monthly ISP payment",
            "maxLength": 2000,
            "type": "string"
          },
          "dueDate": {
            "description": "Optional due date for this bill.",
            "example": "2026-03-15T18:00:00.000Z",
            "format": "date-time",
            "type": "string"
          },
          "incurredAt": {
            "description": "When the bill was incurred. Defaults to now.",
            "example": "2026-03-05T18:00:00.000Z",
            "format": "date-time",
            "type": "string"
          },
          "paidByUserId": {
            "description": "User id of the member who paid this bill.",
            "example": "f5c6304d-7f58-4f67-bf80-4de6f388b310",
            "type": "string"
          },
          "splits": {
            "description": "Split rows. Amounts must sum exactly to totalAmount.",
            "items": {
              "$ref": "#/components/schemas/CreateBillSplitDto"
            },
            "type": "array"
          },
          "title": {
            "description": "Short bill title.",
            "example": "Internet bill - March",
            "maxLength": 160,
            "minLength": 1,
            "type": "string"
          },
          "totalAmount": {
            "description": "Total bill amount. Supports up to 2 decimal places.",
            "example": 76.5,
            "type": "number"
          }
        },
        "required": [
          "title",
          "totalAmount",
          "paidByUserId",
          "splits"
        ],
        "type": "object"
      },
      "CreateBillSplitDto": {
        "properties": {
          "amount": {
            "description": "Amount this user owes for the bill. Supports up to 2 decimal places.",
            "example": 25.5,
            "type": "number"
          },
          "userId": {
            "description": "User id for this split row.",
            "example": "f5c6304d-7f58-4f67-bf80-4de6f388b310",
            "type": "string"
          }
        },
        "required": [
          "userId",
          "amount"
        ],
        "type": "object"
      },
      "CreateChoreDto": {
        "properties": {
          "assigneeUserId": {
            "description": "Optional user ID to assign the chore to at creation time",
            "example": "user-uuid",
            "type": "string"
          },
          "description": {
            "example": "Take out kitchen and bathroom trash before 9pm.",
            "maxLength": 1000,
            "type": "string"
          },
          "dueDate": {
            "description": "Optional ISO-8601 due date for the chore",
            "example": "2026-03-10T21:00:00.000Z",
            "format": "date-time",
            "type": "string"
          },
          "title": {
            "description": "Short, human-readable chore title",
            "example": "Take out trash",
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "title"
        ],
        "type": "object"
      },
      "CreateGroupDto": {
        "properties": {
          "name": {
            "description": "Human-readable roommate group name",
            "example": "Apartment 12A",
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "CreatePaymentDto": {
        "properties": {
          "amount": {
            "description": "Payment amount. Supports up to 2 decimal places.",
            "example": 20,
            "type": "number"
          },
          "billId": {
            "description": "Optional bill id this payment is linked to.",
            "example": "3e4f66fd-7eeb-4c2f-a98e-f94376ea22f5",
            "type": "string"
          },
          "currency": {
            "description": "Three-letter ISO currency code. Defaults to USD.",
            "example": "USD",
            "type": "string"
          },
          "idempotencyKey": {
            "description": "Optional idempotency key for safely retried payment requests.",
            "example": "pay-2026-03-05-group1-user1-user2-20",
            "maxLength": 64,
            "type": "string"
          },
          "note": {
            "description": "Optional payment note.",
            "example": "Paid via Zelle",
            "maxLength": 1000,
            "type": "string"
          },
          "paidAt": {
            "description": "When payment was made. Defaults to now.",
            "example": "2026-03-05T18:15:00.000Z",
            "format": "date-time",
            "type": "string"
          },
          "payeeUserId": {
            "description": "User id of the member receiving payment.",
            "example": "8e9f7f6e-e3b4-468f-a8f4-c35159b844ab",
            "type": "string"
          },
          "payerUserId": {
            "description": "User id of the member sending payment.",
            "example": "f5c6304d-7f58-4f67-bf80-4de6f388b310",
            "type": "string"
          }
        },
        "required": [
          "payerUserId",
          "payeeUserId",
          "amount"
        ],
        "type": "object"
      },
      "GroupMemberRole": {
        "description": "Target role for the member",
        "enum": [
          "ADMIN",
          "MEMBER"
        ],
        "type": "string"
      },
      "JoinGroupDto": {
        "properties": {
          "joinCode": {
            "description": "Join code generated by group admin",
            "example": "AB12CD34",
            "maxLength": 20,
            "minLength": 4,
            "type": "string"
          }
        },
        "required": [
          "joinCode"
        ],
        "type": "object"
      },
      "LoginDto": {
        "properties": {
          "email": {
            "example": "alex@example.com",
            "type": "string"
          },
          "password": {
            "example": "StrongPass123!",
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "RegisterDto": {
        "properties": {
          "email": {
            "example": "alex@example.com",
            "type": "string"
          },
          "fullName": {
            "example": "Alex Smith",
            "type": "string"
          },
          "password": {
            "example": "StrongPass123!",
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "UpdateChoreAssigneeDto": {
        "properties": {
          "assigneeUserId": {
            "description": "User ID of the new assignee. Omit or set to null/undefined to unassign the chore completely.",
            "example": "user-uuid",
            "type": "string"
          }
        },
        "type": "object"
      },
      "UpdateContractDraftDto": {
        "properties": {
          "content": {
            "description": "New draft content for the group contract.",
            "maxLength": 50000,
            "type": "string"
          }
        },
        "required": [
          "content"
        ],
        "type": "object"
      },
      "UpdateMemberRoleDto": {
        "properties": {
          "role": {
            "$ref": "#/components/schemas/GroupMemberRole"
          }
        },
        "required": [
          "role"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer": {
        "bearerFormat": "JWT",
        "description": "Supabase access token",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {},
    "description": "Module 1-2 platform and authentication",
    "title": "RoomieManager Backend API",
    "version": "1.0.0"
  },
