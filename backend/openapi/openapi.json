    "/api/v1/groups/{groupId}/chores": {
      "get": {
        "operationId": "ChoresController_listGroupChores",
        "parameters": [
          {
            "in": "path",
            "name": "groupId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "1-based page number.",
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "example": 1,
