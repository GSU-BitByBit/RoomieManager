{
  "components": {
    "schemas": {
      "LoginDto": {
        "properties": {
          "email": {
            "example": "alex@example.com",
            "type": "string"
          },
          "password": {
            "example": "StrongPass123!",
            "minLength": 8,
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "RegisterDto": {
        "properties": {
          "email": {
            "example": "alex@example.com",
            "type": "string"
          },
          "fullName": {
            "example": "Alex Smith",
            "type": "string"
          },
          "password": {
            "example": "StrongPass123!",
            "minLength": 8,
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer": {
        "bearerFormat": "JWT",
        "description": "Supabase access token",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {},
    "description": "Module 1-2 platform and authentication",
    "title": "RoomieManager Backend API",
    "version": "1.0.0"
  },
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Returns Supabase user and session."
          }
        },
        "summary": "Login with email/password via Supabase Auth",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "operationId": "AuthController_getMe",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Authenticated user identity and claims."
          },
          "401": {
            "description": "Missing or invalid bearer token."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Return current authenticated user from access token claims",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "operationId": "AuthController_register",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Returns Supabase user and optional session."
          }
        },
        "summary": "Register account with email/password via Supabase Auth",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/health/live": {
      "get": {
        "operationId": "HealthController_getLiveness",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Service process is alive."
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/v1/health/ready": {
      "get": {
        "operationId": "HealthController_getReadiness",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Service is ready to accept traffic."
          },
          "503": {
            "description": "Service is not ready."
          }
        },
        "summary": "Readiness probe",
        "tags": [
          "Health"
        ]
      }
    }
  },
  "servers": [],
  "tags": []
}
