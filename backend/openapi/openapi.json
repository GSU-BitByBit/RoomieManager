{
  "components": {
    "schemas": {
      "CreateGroupDto": {
        "properties": {
          "name": {
            "description": "Human-readable roommate group name",
            "example": "Apartment 12A",
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "GroupMemberRole": {
        "description": "Target role for the member",
        "enum": [
          "ADMIN",
          "MEMBER"
        ],
        "type": "string"
      },
      "JoinGroupDto": {
        "properties": {
          "joinCode": {
            "description": "Join code generated by group admin",
            "example": "AB12CD34",
            "maxLength": 20,
            "minLength": 4,
            "type": "string"
          }
        },
        "required": [
          "joinCode"
        ],
        "type": "object"
      },
      "LoginDto": {
        "properties": {
          "email": {
            "example": "alex@example.com",
            "type": "string"
          },
          "password": {
            "example": "StrongPass123!",
            "minLength": 8,
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "RegisterDto": {
        "properties": {
          "email": {
            "example": "alex@example.com",
            "type": "string"
          },
          "fullName": {
            "example": "Alex Smith",
            "type": "string"
          },
          "password": {
            "example": "StrongPass123!",
            "minLength": 8,
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "UpdateMemberRoleDto": {
        "properties": {
          "role": {
            "$ref": "#/components/schemas/GroupMemberRole"
          }
        },
        "required": [
          "role"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer": {
        "bearerFormat": "JWT",
        "description": "Supabase access token",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {},
    "description": "Module 1-2 platform and authentication",
    "title": "RoomieManager Backend API",
    "version": "1.0.0"
  },
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Returns Supabase user and session."
          }
        },
        "summary": "Login with email/password via Supabase Auth",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "operationId": "AuthController_getMe",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Authenticated user identity and claims."
          },
          "401": {
            "description": "Missing or invalid bearer token."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Return current authenticated user from access token claims",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "operationId": "AuthController_register",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Returns Supabase user and optional session."
          }
        },
        "summary": "Register account with email/password via Supabase Auth",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/groups": {
      "post": {
        "operationId": "GroupsController_createGroup",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateGroupDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Group created with admin membership and join code."
          },
          "401": {
            "description": "Missing or invalid bearer token."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Create a roommate group. Creator becomes admin.",
        "tags": [
          "Groups"
        ]
      }
    },
    "/api/v1/groups/{groupId}": {
      "get": {
        "operationId": "GroupsController_getGroup",
        "parameters": [
          {
            "in": "path",
            "name": "groupId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns group metadata and caller membership context."
          },
          "401": {
            "description": "Missing or invalid bearer token."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get group summary for current member.",
        "tags": [
          "Groups"
        ]
      }
    },
    "/api/v1/groups/{groupId}/join-code/reset": {
      "post": {
        "operationId": "GroupsController_resetJoinCode",
        "parameters": [
          {
            "in": "path",
            "name": "groupId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns newly generated join code."
          },
          "401": {
            "description": "Missing or invalid bearer token."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Reset group join code (admin only).",
        "tags": [
          "Groups"
        ]
      }
    },
    "/api/v1/groups/{groupId}/members": {
      "get": {
        "operationId": "GroupsController_getGroupMembers",
        "parameters": [
          {
            "in": "path",
            "name": "groupId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns current group members with roles and statuses."
          },
          "401": {
            "description": "Missing or invalid bearer token."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "List active members in the group.",
        "tags": [
          "Groups"
        ]
      }
    },
    "/api/v1/groups/{groupId}/members/{userId}": {
      "delete": {
        "operationId": "GroupsController_removeMember",
        "parameters": [
          {
            "in": "path",
            "name": "groupId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "userId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Marks target member as inactive and returns result."
          },
          "401": {
            "description": "Missing or invalid bearer token."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Remove member from group (admin only).",
        "tags": [
          "Groups"
        ]
      }
    },
    "/api/v1/groups/{groupId}/members/{userId}/role": {
      "patch": {
        "operationId": "GroupsController_updateMemberRole",
        "parameters": [
          {
            "in": "path",
            "name": "groupId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "userId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateMemberRoleDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Returns updated member role state."
          },
          "401": {
            "description": "Missing or invalid bearer token."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Update group member role (admin only).",
        "tags": [
          "Groups"
        ]
      }
    },
    "/api/v1/groups/join": {
      "post": {
        "operationId": "GroupsController_joinGroup",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinGroupDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Joins group as member and returns group context."
          },
          "401": {
            "description": "Missing or invalid bearer token."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Join a group using join code.",
        "tags": [
          "Groups"
        ]
      }
    },
    "/api/v1/health/live": {
      "get": {
        "operationId": "HealthController_getLiveness",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Service process is alive."
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/v1/health/ready": {
      "get": {
        "operationId": "HealthController_getReadiness",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Service is ready to accept traffic."
          },
          "503": {
            "description": "Service is not ready."
          }
        },
        "summary": "Readiness probe",
        "tags": [
          "Health"
        ]
      }
    }
  },
  "servers": [],
  "tags": []
}
