              "type": "number"
            }
          },
          {
            "description": "Maximum number of items per page.",
            "in": "query",
            "name": "pageSize",
            "required": false,
            "schema": {
              "example": 20,
              "maximum": 100,
              "minimum": 1,
              "type": "number"
            }
          },
          {
            "description": "Optional filter by status (PENDING or COMPLETED)",
            "in": "query",
            "name": "status",
            "required": false,
