    "/api/v1/groups/{groupId}/bills": {
      "get": {
        "operationId": "FinanceController_listBills",
        "parameters": [
          {
            "in": "path",
            "name": "groupId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "1-based page number.",
            "in": "query",
            "name": "page",
